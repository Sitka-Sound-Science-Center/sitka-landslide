{
  "name": "landslide-app",
  "private": true,
  "scripts": {
    "dev": "yarn get-data && next dev -p 3008",
    "analyze": "cross-env ANALYZE=true next build",
    "build": "yarn get-data && next build",
    "export": "yarn build && next export && cp data/rainfall.json out/data/rainfall.json",
    "start": "next start",
    "lint": "next lint",
    "check-format": "prettier --check '{pages,components}/*.{js,jsx,json,css}'",
    "fix-format": "prettier --write '{pages,components}/*.{js,jsx,json,css}'",
    "get-data": "node data/getRainfall.js"
  },
  "dependencies": {
    "@mdx-js/loader": "^2.1.0",
    "@next/mdx": "^12.1.0",
    "@nivo/core": "^0.79.0",
    "@nivo/scatterplot": "^0.79.1",
    "axios": "^0.26.1",
    "axios-retry": "^3.2.5",
    "d3": "^7.3.0",
    "luxon": "^2.3.1",
    "mapbox-gl": "^2.6.1",
    "next": "12.1",
    "react": "17.0.2",
    "react-accessible-accordion": "^4.0.0",
    "react-accessible-dropdown-menu-hook": "^3.2.0",
    "react-dom": "17.0.2",
    "timeago.js": "^4.0.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^12.1.0",
    "critters": "^0.0.16",
    "cross-env": "^7.0.3",
    "eslint": "8.7.0",
    "eslint-config-next": "12.0.9",
    "fs": "0.0.1-security",
    "path": "^0.12.7",
    "prettier": "2.5.1"
  }
}
