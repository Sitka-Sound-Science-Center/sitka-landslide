#!/bin/bash

set -e

function usage() {
    echo -n \
        "Usage: $(basename "$0")
Run autoformatter in 'write' mode.
"
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    if [ "${1:-}" = "--help" ]; then
        usage
    else
        source "$(dirname $0)"/activate_yvm
        pushd frontend
        yarn run fix-format
    fi
fi
