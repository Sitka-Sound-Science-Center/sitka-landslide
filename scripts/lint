#!/bin/bash

set -e

function usage() {
    echo -n \
        "Usage: $(basename "$0")
Check the code for lint or formatting issues.
"
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    if [ "${1:-}" = "--help" ]; then
        usage
    else
        source "$(dirname $0)"/activate_yvm
        pushd frontend
        yarn run lint
        yarn run check-format
    fi
fi
